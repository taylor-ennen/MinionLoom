# Ignore everything by default
/*

# Allow git metadata and ignore config
!.gitignore

# Allow the minions plugin folder (only this folder is tracked)
!/.github/
/.github/*
!.github/minions/
!.github/minions/**

# Optional: if you ever want to allow additional project files, unignore them explicitly.
# Example:
# !/some-other-folder/
# !/some-file.ext
